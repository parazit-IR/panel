DATABASE_URL=jdbc:postgresql://localhost:5432/panel_db
DATABASE_USERNAME=panel
DATABASE_PASSWORD=panel

DB_POOL_NAME=PanelHikariPool
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000

REDIS_HOST=localhost
REDIS_PORT=6379

TELEGRAM_ENABLED=false
BOT_TOKEN=

PANEL_ENABLED=false
PANEL_URL=http://localhost:2053
PANEL_USERNAME=admin
PANEL_PASSWORD=admin

PAYMENT_ENABLED=false
PAYMENT_MERCHANT_ID=
PAYMENT_DEFAULT_EXPIRATION=PT30M
ZARINPAL_ENABLED=false
ZARINPAL_MERCHANT_ID=
ZARINPAL_API_BASE_URL=https://api.zarinpal.com
ZARINPAL_STARTPAY_BASE_URL=https://www.zarinpal.com/pg/StartPay
ZARINPAL_REQUEST_PATH=/pg/v4/payment/request.json
ZARINPAL_VERIFY_PATH=/pg/v4/payment/verify.json
ZARINPAL_CALLBACK_BASE_URL=https://example.com/api/payments/zarinpal/callback
ZARINPAL_SUCCESS_REDIRECT_URL=https://example.com/payment/success
ZARINPAL_FAILURE_REDIRECT_URL=https://example.com/payment/failed
ZARINPAL_CANCEL_REDIRECT_URL=https://example.com/payment/cancelled
ZARINPAL_CONNECT_TIMEOUT=PT5S
ZARINPAL_READ_TIMEOUT=PT20S
ZARINPAL_MAX_TRANSIENT_RETRIES=0
ZARINPAL_RETRY_DELAY=PT1S
ZARINPAL_SANDBOX_ENABLED=false
ZARINPAL_VERIFY_SSL=true

XUI_BASE_URL=http://localhost:2053
XUI_USERNAME=
XUI_PASSWORD=
XUI_CONNECT_TIMEOUT=5s
XUI_READ_TIMEOUT=20s
XUI_LOGIN_TIMEOUT=10s
XUI_MAX_RETRIES=3
XUI_RETRY_DELAY=1s
XUI_VERIFY_SSL=true
XUI_AUTO_LOGIN=true
XUI_SESSION_TIMEOUT=PT30M
XUI_INBOUND_LIST_PATH=/panel/api/inbounds/list
XUI_CLIENT_CREATE_PATH=/panel/api/inbounds/addClient
XUI_CLIENT_UPDATE_PATH_TEMPLATE=/panel/api/inbounds/updateClient/{clientId}
XUI_CLIENT_DELETE_PATH_TEMPLATE=/panel/api/inbounds/{inboundId}/delClient/{clientId}
XUI_CLIENT_RESET_TRAFFIC_PATH_TEMPLATE=/panel/api/clients/resetTraffic/{email}
XUI_CLIENT_TRAFFIC_PATH_TEMPLATE=/panel/api/clients/traffic/{email}
XUI_CLIENT_CLEAR_IPS_PATH_TEMPLATE=/panel/api/clients/clearIps/{email}
XUI_CLIENT_DEFAULT_FLOW=xtls-rprx-vision
XUI_SUBSCRIPTION_ID_LENGTH=16
XUI_CLIENT_RECONCILIATION_ATTEMPTS=1

REFERRAL_ENABLED=true
REFERRAL_CODE_LENGTH=10

PLAN_SELECTION_TTL=PT30M
